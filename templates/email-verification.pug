doctype html
html(lang='en')
	head
		meta(charset='UTF-8')
		meta(name='viewport', content='width=device-width, initial-scale=1.0')
		title Verify Email Address
	body(style='font-family: Arial, sans-serif; line-height: 1.6; color: #333;')
		- const baseDomain = domain.replace(/\/$/, '')
		- const verificationLink = `${baseDomain}/verify-email?token=${token}`
		h2 Hello #{name},
		p Thank you for signing up for #{app_name}.
		p Click the button below to verify your email address:
		p
			a(
				href=verificationLink,
				style='display: inline-block; padding: 10px 16px; background-color: #1f6feb; color: #fff; text-decoration: none; border-radius: 6px; font-weight: bold;'
			) Verify Email
		p(style='margin-top: 16px;') If the button does not work, use this link:
		p
			a(href=verificationLink) #{verificationLink}
		p If you did not create an account, please ignore this email.
