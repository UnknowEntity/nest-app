doctype html
html(lang='en')
	head
		meta(charset='UTF-8')
		meta(name='viewport', content='width=device-width, initial-scale=1.0')
		title Reset Password
	body(style='font-family: Arial, sans-serif; line-height: 1.6; color: #333;')
		- const baseDomain = domain.replace(/\/$/, '')
		- const resetLink = `${baseDomain}/reset-password?token=${token}`
		h2 Hello #{userName},
		p We received a request to reset your password.
		p Click the button below to reset your password:
		p
			a(
				href=resetLink,
				style='display: inline-block; padding: 10px 16px; background-color: #1f6feb; color: #fff; text-decoration: none; border-radius: 6px; font-weight: bold;'
			) Reset Password
		p(style='margin-top: 16px;') If the button does not work, use this link:
		p
			a(href=resetLink) #{resetLink}
		p If you did not request this, please ignore this email.
